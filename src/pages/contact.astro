---
import Layout from "@/src/layouts/layout.astro";

import { Hexagon } from "@/src/components/hexagon";
---

<Layout>
  <section class="pt-36 pb-24 md:py-56">
    <div class="relative overflow-x-clip">
      <div
        class="absolute top-1/2 left-1/2 hidden -translate-x-1/2 -translate-y-1/2 md:block"
      >
        <Hexagon size={1000} duration={30} client:load />
      </div>
      <div
        class="absolute top-1/2 left-1/2 hidden -translate-x-1/2 -translate-y-1/2 md:block"
      >
        <Hexagon size={1400} duration={50} reverse client:load />
      </div>

      <div class="container mx-auto px-4">
        <div class="mx-auto max-w-3xl">
          <p
            class="text-center text-lg font-bold tracking-wider text-slate-700 uppercase"
          >
            Get in Touch
          </p>
          <h1
            class="mx-auto mt-4 max-w-2xl text-center text-4xl leading-10 font-extrabold text-slate-800 md:text-6xl md:leading-14"
          >
            Have any Questions or Feedback?
          </h1>
          <p
            class="mx-auto mt-6 max-w-xl text-center font-serif text-xl text-slate-700 md:text-3xl"
          >
            We'd love to hear from you. Whether it's a question about our
            courses, a suggestion, or just a friendly hello, feel free to reach
            out.
          </p>
        </div>

        <div class="mt-10 flex justify-center">
          <button
            class="group relative flex cursor-pointer justify-center overflow-hidden px-4 py-2 font-semibold tracking-wide uppercase transition-all duration-300"
          >
            <div
              class="absolute inset-0 outline-2 -outline-offset-2 outline-green-700 transition-all duration-300 group-hover:bg-green-700/10"
            >
            </div>
            <div
              class="absolute inset-0 -z-10 origin-left scale-x-0 transform bg-green-700 transition-transform duration-300 ease-out group-hover:scale-x-100"
            >
            </div>
            <span
              class="relative z-10 leading-6 text-green-700 transition-colors duration-300 group-hover:text-white"
            >
              Contact Us
            </span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-0 pb-24 md:pt-52 md:pb-16">
    <div class="container mx-auto flex max-w-2xl flex-col gap-6 px-4 md:gap-8">
      <form
        action="https://formsubmit.co/neilivanorencia@gmail.com"
        method="POST"
        class="mt-0 flex flex-col md:mt-4"
      >
        <label for="name" class="font-serif text-lg text-slate-800 md:text-xl"
          >Name</label
        >
        <div class="relative mt-2">
          <input
            type="text"
            name="name"
            id="name"
            class="w-full border-0 bg-transparent px-3 py-2 font-serif text-base text-slate-700 outline-2 -outline-offset-2 outline-teal-500 md:text-lg"
            style="min-height: 3rem;"
            required
          />
        </div>

        <label
          for="email"
          class="mt-6 font-serif text-lg text-slate-800 md:text-xl">Email</label
        >
        <div class="relative mt-2">
          <input
            type="email"
            name="email"
            id="email"
            class="w-full border-0 bg-transparent px-3 py-2 font-serif text-base text-slate-700 outline-2 -outline-offset-2 outline-teal-500 md:text-lg"
            style="min-height: 3rem;"
            required
          />
        </div>

        <label
          for="message"
          class="mt-6 font-serif text-lg text-slate-800 md:text-xl"
          >Message</label
        >
        <div class="relative mt-2">
          <textarea
            name="message"
            id="message"
            class="resize-vertical w-full border-0 bg-transparent px-3 py-2 font-serif text-base text-slate-700 outline-2 -outline-offset-2 outline-teal-500 md:text-lg"
            style="min-height: 8rem;"
            required></textarea>
        </div>

        <button
          type="submit"
          class="group relative mt-8 flex w-full cursor-pointer justify-center overflow-hidden px-3 py-2 text-sm font-semibold tracking-wide text-teal-500 uppercase transition-all duration-300 md:px-4 md:text-base"
        >
          <div
            class="absolute inset-0 outline-2 -outline-offset-2 outline-teal-500 transition-all duration-300 group-hover:bg-teal-400/10"
          >
          </div>
          <div
            class="absolute inset-0 -z-10 origin-left scale-x-0 transform bg-teal-500 transition-transform duration-300 ease-out group-hover:scale-x-100"
          >
          </div>
          <span
            class="relative z-10 transition-colors duration-300 group-hover:text-white"
          >
            Send message
          </span>
        </button>
      </form>
    </div>
  </section>
</Layout>
